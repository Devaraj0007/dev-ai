# Copy this file to .env and add your own OpenRouter key.
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Fast, capable general-purpose model.
RESEARCH_AGENT_MODEL=google/gemini-2.5-flash:nitro
RESEARCH_AGENT_MODE=research
RESEARCH_AGENT_TOP_K=4
RESEARCH_AGENT_MIN_SCORE=0.05

OPENROUTER_SITE_URL=https://github.com/research-agent
OPENROUTER_SITE_NAME=AI Assistant
