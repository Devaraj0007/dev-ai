# ── Application ──────────────────────────────────────────────────────────
DEBUG=false
JWT_SECRET_KEY=change-this-to-a-secure-random-string-in-production

# ── Database ─────────────────────────────────────────────────────────────
# SQLite (default for local dev):
DATABASE_URL=sqlite:///./research_platform.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/research_platform

# ── Redis & Celery (optional — for background tasks) ────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── LLM Provider API Keys & Fallback Chain ─────────────────────────────
# Dev AI uses an automatic 3-tier LLM provider fallback chain:
#   1. gemini-3.6-flash (via GEMINI_API_KEY — requires paid/billing enabled Gemini API key)
#   2. gemini-3-flash (via GEMINI_API_KEY — automatically falls back if 3.6 encounters a quota/billing error; works on free tier)
#   3. NVIDIA NIM (via NVIDIA_API_KEY — final fallback if Gemini key is absent or all Gemini attempts fail)

GEMINI_API_KEY=your-gemini-api-key-here
NVIDIA_API_KEY=your-nvidia-nim-key-here
# OPENROUTER_API_KEY=your-openrouter-key-here
# OPENAI_API_KEY=your-openai-key-here
# ANTHROPIC_API_KEY=your-anthropic-key-here

# ── Model Configuration ─────────────────────────────────────────────────
# NVIDIA NIM model catalog names (see https://build.nvidia.com/models)
RESEARCH_MODEL=meta/llama-3.1-70b-instruct
FAST_MODEL=meta/llama-3.1-70b-instruct
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Vector Database ─────────────────────────────────────────────────────
# Options: local | chroma | faiss | pinecone | weaviate
VECTOR_DB_TYPE=local
# CHROMA_PERSIST_DIR=./chroma_data
# FAISS_INDEX_PATH=./faiss_index
# PINECONE_API_KEY=your-pinecone-key
# PINECONE_ENV=us-east-1
# PINECONE_INDEX=research-agent

# ── Reranking ────────────────────────────────────────────────────────────
# Options: hybrid | cohere | cross-encoder | bm25
RERANKER_TYPE=hybrid
# COHERE_API_KEY=your-cohere-key-here

# ── Web Search ───────────────────────────────────────────────────────────
ENABLE_WEB_SEARCH=true
# TAVILY_API_KEY=your-tavily-key-here
# SERPER_API_KEY=your-serper-key-here
# Falls back to DuckDuckGo (free, no key needed)

# ── File Storage ─────────────────────────────────────────────────────────
UPLOAD_DIR=uploaded_docs
MAX_UPLOAD_SIZE_MB=50

# ── CORS ─────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Rate Limiting ────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30
